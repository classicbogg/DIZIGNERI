DJANGO_SECRET_KEY=replace-with-production-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,sielom-web.online,www.sielom-web.online

# Локально по умолчанию SQLite, чтобы проект запускался сразу.
USE_SQLITE=1

# PostgreSQL (используется при USE_SQLITE=0)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=sielom
DB_USER=sielom
DB_PASSWORD=sielom
DB_HOST=127.0.0.1
DB_PORT=5432

SECURE_SSL_REDIRECT=0
SECURE_HSTS_SECONDS=0